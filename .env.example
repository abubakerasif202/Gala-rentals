# Backend
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional for basic startup. A session-capable Postgres connection (port 5432)
# is required for payment links and automatic activation.
SUPABASE_DB_URL=your_direct_postgres_connection_string
ADMIN_EMAIL=admin@maplerentals.com.au
APP_URL=http://localhost:3000
JWT_SECRET=replace_with_a_long_random_secret
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: pin reusable Stripe catalog products. If omitted, the app will
# create or reuse canonical products automatically in Stripe.
# STRIPE_SECURITY_BOND_PRODUCT_ID=prod_...
# STRIPE_ONBOARDING_SETUP_PRODUCT_ID=prod_...
# STRIPE_WEEKLY_RENTAL_PRODUCT_ID=prod_...
CHECKOUT_LINK_SECRET=replace_with_a_long_random_secret
LEASE_OWNER_NAME=Maple Rentals
LEASE_OWNER_ADDRESS=13/27-33 Addlestone Rd, Merrylands NSW 2160
LEASE_OWNER_CONTACT=0420 550 556
LEASE_OWNER_EMAIL=admin@maplerentals.com.au
RESEND_API_KEY=re_...
INDEXNOW_ENABLED=false
INDEXNOW_KEY=your-indexnow-key-here
SITE_URL=http://localhost:3000
# Optional local-only admin fallback login for development.
# ADMIN_PASSWORD=change_me
# Optional: override network timeout/debounce settings for IndexNow submissions.
# INDEXNOW_TIMEOUT_MS=7000
# INDEXNOW_DEBOUNCE_MS=2000

# Frontend Variables (VITE_ prefix required)
VITE_API_BASE_URL=/api

# Optional overrides
# FRONTEND_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000
# JSON_BODY_LIMIT=100kb
# LEASE_RETURN_NOTICE_DAYS=14
