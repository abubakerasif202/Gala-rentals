# NODE_ENV is managed by npm/Vite locally and by Render in production.
# NODE_ENV=production
PORT=3000

# Public production URLs
PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
VITE_API_BASE_URL=/api
# FRONTEND_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000
# JSON_BODY_LIMIT=100kb

# Admin login
ADMIN_EMAIL=admin@galarentals.com.au
# Local-only admin fallback login for development. Do not use in production.
# ADMIN_PASSWORD=change_me

# Database
# Use Supabase DIRECT/session-capable Postgres URL, not transaction pooler
DATABASE_URL=
SUPABASE_DB_URL=

# Supabase backend secrets
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VEHICLE_IMAGES_BUCKET=vehicle-images

# Supabase frontend public vars
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_VEHICLE_IMAGES_BUCKET=vehicle-images

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLIC_KEY=
CHECKOUT_LINK_SECRET=
