# Direct PostgreSQL
# Render Postgres should be wired here for transactional app data and Stripe/payment state.
# Production requires a direct/session-capable connection; do not use a transaction pooler URL.
# Preferred in all new environments.
DATABASE_URL=
# Legacy fallback for existing environments that still use a direct Supabase Postgres connection.
# The server and migration scripts prefer DATABASE_URL when both are set.
SUPABASE_DB_URL=

# Supabase storage and auth
# Required for Supabase Storage, signed document URLs, and Supabase-backed auth flows.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
# Required to generate hosted Checkout Sessions, verify webhooks, and sign secure payment links.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_LINK_SECRET=
# Optional: pin reusable Stripe catalog products. If omitted, the app will create or reuse
# the canonical products automatically in Stripe.
# STRIPE_SECURITY_BOND_PRODUCT_ID=prod_...
# STRIPE_ONBOARDING_SETUP_PRODUCT_ID=prod_...
# STRIPE_WEEKLY_RENTAL_PRODUCT_ID=prod_...

# App and security
# Required for admin auth, signed cookies, and checkout redirect URLs.
APP_URL=http://localhost:3000
ADMIN_EMAIL=hello@galarentals.com.au
JWT_SECRET=replace_with_at_least_32_random_characters
SITE_URL=http://localhost:3000

# Lease agreement defaults
LEASE_OWNER_NAME=Gala Rentals
LEASE_OWNER_ADDRESS=Sydney NSW
LEASE_OWNER_CONTACT=1300 555 828
LEASE_OWNER_EMAIL=hello@galarentals.com.au

# Optional integrations
RESEND_API_KEY=
INDEXNOW_ENABLED=false
INDEXNOW_KEY=your-indexnow-key-here

# Frontend
VITE_API_BASE_URL=/api
VITE_STRIPE_PUBLIC_KEY=pk_test_...
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_VEHICLE_IMAGES_BUCKET=vehicle-images

# Optional overrides
# FRONTEND_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000
# JSON_BODY_LIMIT=100kb
# LEASE_RETURN_NOTICE_DAYS=14
# INDEXNOW_TIMEOUT_MS=7000
# INDEXNOW_DEBOUNCE_MS=2000

# Local-only admin fallback login for development. Do not use in production.
# ADMIN_PASSWORD=change_me
