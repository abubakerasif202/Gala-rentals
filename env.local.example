# NODE_ENV is managed by npm/Vite locally and by Render in production.
# NODE_ENV=production
PORT=3000

# Public production URLs
PUBLIC_SITE_URL=https://www.galarentals.com.au
SITE_URL=https://www.galarentals.com.au
VITE_API_BASE_URL=/api

# Admin login
ADMIN_EMAIL=admin@gala-rentals.local
ADMIN_PASSWORD=change_me

# Database
# Use Supabase DIRECT/session-capable Postgres URL, not transaction pooler
DATABASE_URL=postgresql://postgres.example:password@host:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.example:password@host:5432/postgres

# Supabase backend secrets
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_VEHICLE_IMAGES_BUCKET=vehicle-images

# Supabase frontend public vars
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_VEHICLE_IMAGES_BUCKET=vehicle-images

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
VITE_STRIPE_PUBLIC_KEY=pk_test_replace_me
CHECKOUT_LINK_SECRET=replace_with_a_long_random_secret
# STRIPE_SECURITY_BOND_PRODUCT_ID=prod_...
# STRIPE_ONBOARDING_SETUP_PRODUCT_ID=prod_...
# STRIPE_WEEKLY_RENTAL_PRODUCT_ID=prod_...

# Email / Resend
RESEND_API_KEY=replace_me
CONTACT_FROM_EMAIL=hello@example.com
CONTACT_TO_EMAIL=ops@example.com

# SEO / indexing
INDEXNOW_KEY=replace_me
INDEXNOW_ENABLED=false

# App security
JWT_SECRET=replace_with_at_least_32_random_characters

# Required for signed checkout links, redirects, and webhook checks.
APP_URL=https://www.galarentals.com.au

# Lease agreement defaults
LEASE_OWNER_NAME=Gala Rentals
LEASE_OWNER_ADDRESS=Sydney NSW
LEASE_OWNER_CONTACT=1300 555 828
LEASE_OWNER_EMAIL=hello@gala-rentals.com.au

# Optional local overrides. Leave commented unless needed.
# FRONTEND_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000
# JSON_BODY_LIMIT=100kb
# LEASE_RETURN_NOTICE_DAYS=14
# INDEXNOW_TIMEOUT_MS=7000
# INDEXNOW_DEBOUNCE_MS=2000
