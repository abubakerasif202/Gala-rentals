{
  "name": "maple-rental",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch api/index.ts",
    "start": "node server-dist/api/index.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "node scripts/run-vite.js build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "node scripts/run-vite.js preview",
    "clean": "node scripts/clean.js",
    "clean:documents": "tsx scripts/cleanup-orphaned-documents.ts",
    "migrate:payment-workflow": "node scripts/migrate-payment-workflow-upgrade.js",
    "migrate:legacy-snake-payment-workflow": "node scripts/migrate-legacy-snake-case-payment-workflow.js",
    "migrate:stripe-webhook-ledger": "node scripts/migrate-stripe-webhook-ledger.js",
    "migrate:vehicle-allocation": "node scripts/migrate-active-vehicle-allocation.js",
    "migrate:operational-history": "node scripts/migrate-operational-history.js",
    "migrate:application-indexes": "node scripts/migrate-application-indexes.js",
    "verify:schema-contract": "tsx scripts/verify-production-schema-contract.js",
    "sync:realtime-fleet": "node scripts/sync-realtime-fleet.js",
    "stripe:setup": "tsx scripts/stripe-setup.ts",
    "stripe:handoff": "tsx scripts/stripe-setup.ts --require-live",
    "stripe:reset": "tsx scripts/stripe-reset.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "validate": "npm run lint && npm run test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.0.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "20.x"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
