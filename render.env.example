# Gala Rentals Render environment variables
# Copy these into the Render service Environment tab.
# Do not commit real secrets here.

NODE_ENV=production
APP_URL=https://www.galarentals.com.au
ADMIN_EMAIL=hello@gala-rentals.com.au

# Postgres
# Use a session-capable direct connection for transactional payment activation.
# Keep DATABASE_URL as the primary value. Use SUPABASE_DB_URL only if DATABASE_URL is unavailable.
# Do not use a transaction pooler URL here.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_LINK_SECRET=

JWT_SECRET=
RESEND_API_KEY=

VITE_API_BASE_URL=/api
# Frontend-only values must not include database credentials or service-role secrets.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_VEHICLE_IMAGES_BUCKET=vehicle-images

LEASE_OWNER_NAME=Gala Rentals
LEASE_OWNER_ADDRESS=Sydney NSW
LEASE_OWNER_CONTACT=1300 555 828
LEASE_OWNER_EMAIL=hello@gala-rentals.com.au
