{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "server-dist",
    "rootDir": ".",
    "lib": ["ES2022"],
    "types": ["node"],
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "noEmit": false
  },
  "include": ["api/**/*.ts", "shared/**/*.ts", "src/lib/rentalPlans.ts"],
  "exclude": ["api/tests/**/*", "shared/**/*.test.ts", "dist", "server-dist", "node_modules"]
}
